{
  "name": "point-to-point",
  "private": true,
  "packageManager": "pnpm@10.21.0",
  "scripts": {
    "dev": "pnpm --filter @p2p/contracts build && turbo run dev --parallel",
    "build": "turbo run build",
    "start": "turbo run start --parallel",
    "test": "turbo run test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.4",
    "turbo": "^2.5.6",
    "typescript": "^5.7.3"
  }
}
